<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="apple-mobile-web-app-status-bar-style" content="default"/>
<meta name="apple-mobile-web-app-title" content="StayOS"/>
<meta name="theme-color" content="#F4F3F0"/>
<title>StayOS</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet"/>
<script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
<script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
<script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{height:100%;background:#F4F3F0;font-family:'DM Sans',sans-serif;color:#1A1A2E;overscroll-behavior:none}
::-webkit-scrollbar{display:none}
input,textarea,select{font-family:inherit;font-size:16px}
#root{height:100%;display:flex;flex-direction:column}
.card{background:white;border-radius:18px;padding:18px;box-shadow:0 1px 4px rgba(0,0,0,0.07)}
.btn{display:inline-flex;align-items:center;justify-content:center;gap:6px;padding:13px 20px;border-radius:13px;font-family:inherit;font-size:15px;font-weight:600;cursor:pointer;border:none;transition:all 0.12s}
.btn:active{transform:scale(0.96)}
.btn-primary{background:#1A1A2E;color:white}
.btn-outline{background:white;color:#1A1A2E;border:1.5px solid #E2DDD7}
.btn-sm{padding:9px 14px;font-size:13px;border-radius:10px}
.badge{display:inline-flex;align-items:center;padding:4px 10px;border-radius:20px;font-size:12px;font-weight:600}
.input{width:100%;padding:14px 15px;border:1.5px solid #E8E5DF;border-radius:13px;font-size:16px;font-family:inherit;outline:none;transition:border 0.15s;background:white;-webkit-appearance:none}
.input:focus{border-color:#1A1A2E}
.sheet-bg{position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:50;backdrop-filter:blur(2px)}
.sheet{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:430px;background:white;border-radius:24px 24px 0 0;z-index:51;max-height:92vh;overflow-y:auto;padding:0 0 40px}
.sheet-handle{width:38px;height:4px;background:#DDD;border-radius:2px;margin:14px auto 20px}
.progress-bar{height:6px;background:#F0EDE8;border-radius:3px;overflow:hidden}
.progress-fill{height:100%;border-radius:3px}
.row{display:flex;align-items:center;gap:12px;padding:14px 0;border-bottom:1px solid #F5F3F0}
.row:last-child{border-bottom:none}
@keyframes fadeUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
.fade-up{animation:fadeUp 0.28s ease}
@keyframes toastIn{from{opacity:0;transform:translateX(-50%) translateY(10px)}to{opacity:1;transform:translateX(-50%) translateY(0)}}
.toast{position:fixed;bottom:90px;left:50%;transform:translateX(-50%);background:#1A1A2E;color:white;padding:13px 22px;border-radius:30px;font-size:14px;font-weight:500;z-index:999;animation:toastIn 0.25s ease;white-space:nowrap;box-shadow:0 6px 24px rgba(0,0,0,0.25)}
.cal-cell{width:40px;height:40px;display:flex;align-items:center;justify-content:center;border-radius:10px;font-size:14px;cursor:pointer;position:relative;transition:all 0.12s}
.checklist-row{display:flex;align-items:center;gap:12px;padding:13px 0;border-bottom:1px solid #F5F3F0}
.section-title{font-size:18px;font-weight:700;margin-bottom:14px;letter-spacing:-0.3px}
.page-header{padding:16px 20px 8px;flex-shrink:0}
.page-scroll{flex:1;overflow-y:auto;padding:0 16px 20px;display:flex;flex-direction:column;gap:14px}
.empty-state{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:48px 24px;color:#AAA;gap:12px;text-align:center}
.field-label{font-size:13px;font-weight:600;color:#888;display:block;margin-bottom:8px}
</style>
</head>
<body>
<div id="root"></div>
<script type="text/babel">
const {useState,useEffect}=React;
const PCOLORS=["#E3F2F9","#FDF3E7","#E8F5E9","#F3E5F5","#FFF8E1","#FCE4EC"];
const PIMAGES=["🏖️","🗼","⛷️","⚓","🏡","🌿","🏙️","🌊"];
const fmt=n=>new Intl.NumberFormat("fr-FR",{style:"currency",currency:"EUR",maximumFractionDigits:0}).format(n);
const todayStr=new Date().toISOString().split("T")[0];
const SC={confirmed:"#4CAF93",active:"#3B9EEB",completed:"#9E9E9E",pending:"#F5A623",done:"#4CAF93"};
const SL={confirmed:"Confirmé",active:"En cours",completed:"Terminé",pending:"En attente",done:"Fait"};
const uid=()=>Math.random().toString(36).slice(2,9);
const load=k=>{ try{ const v=localStorage.getItem(k); return v?JSON.parse(v):null; }catch(e){ return null; }};
const save=(k,v)=>{ try{ localStorage.setItem(k,JSON.stringify(v)); }catch(e){} };

const NAV=[{id:"dashboard",icon:"⊞",label:"Accueil"},{id:"reservations",icon:"📋",label:"Réservations"},{id:"calendar",icon:"📅",label:"Calendrier"},{id:"properties",icon:"🏠",label:"Biens"},{id:"more",icon:"···",label:"Plus"}];
const MORE_MENU=[{id:"messages",icon:"💬",label:"Messages auto"},{id:"cleaning",icon:"🧹",label:"Ménage"},{id:"pricing",icon:"💰",label:"Prix dynamiques"},{id:"stats",icon:"📊",label:"Statistiques"},{id:"locks",icon:"🔐",label:"Serrures"},{id:"guides",icon:"📖",label:"Guides clients"}];

function App(){
  const[page,setPage]=useState("dashboard");
  const[toast,setToast]=useState(null);
  const[showMore,setShowMore]=useState(false);
  const[calMonth,setCalMonth]=useState(new Date());
  const[properties,setPropertiesRaw]=useState(()=>load("stayos_props")||[]);
  const[reservations,setReservationsRaw]=useState(()=>load("stayos_res")||[]);
  const[tasks,setTasksRaw]=useState(()=>load("stayos_tasks")||[]);
  const[templates,setTemplatesRaw]=useState(()=>load("stayos_tmpl")||[
    {id:"t1",name:"Confirmation réservation",trigger:"on_booking",channel:"email",content:"Bonjour {client}, votre réservation à {property} du {checkin} au {checkout} est confirmée ! Code : {code}."},
    {id:"t2",name:"Instructions arrivée",trigger:"24h_before",channel:"whatsapp",content:"Bonjour {client} 👋 Votre séjour commence demain ! Code : {code}. Bon voyage !"},
    {id:"t3",name:"Rappel check-out",trigger:"checkout_day",channel:"whatsapp",content:"Bonjour {client}, check-out avant 11h. Merci pour votre séjour à {property} 🙏"},
  ]);
  const setProperties=v=>{setPropertiesRaw(v);save("stayos_props",v)};
  const setReservations=v=>{setReservationsRaw(v);save("stayos_res",v)};
  const setTasks=v=>{setTasksRaw(v);save("stayos_tasks",v)};
  const setTemplates=v=>{setTemplatesRaw(v);save("stayos_tmpl",v)};
  const showToast=msg=>{setToast(msg);setTimeout(()=>setToast(null),2800)};
  const navigate=p=>{setPage(p);setShowMore(false)};
  const totalRevenue=reservations.reduce((s,r)=>s+(r.total||0),0);
  const activeRes=reservations.filter(r=>r.status==="active").length;
  const todayCheckins=reservations.filter(r=>r.checkin===todayStr).length;
  const todayCheckouts=reservations.filter(r=>r.checkout===todayStr).length;
  const sp={properties,setProperties,reservations,setReservations,tasks,setTasks,templates,setTemplates,showToast,navigate};
  return(
    <div style={{maxWidth:430,margin:"0 auto",height:"100vh",display:"flex",flexDirection:"column",background:"#F4F3F0",position:"relative",overflow:"hidden"}}>
      <div style={{height:8,background:"#F4F3F0",flexShrink:0}}/>
      <div style={{flex:1,overflow:"hidden",display:"flex",flexDirection:"column"}}>
        {page==="dashboard"&&<Dashboard {...sp} totalRevenue={totalRevenue} activeRes={activeRes} todayCheckins={todayCheckins} todayCheckouts={todayCheckouts}/>}
        {page==="reservations"&&<Reservations {...sp}/>}
        {page==="calendar"&&<Calendar {...sp} calMonth={calMonth} setCalMonth={setCalMonth}/>}
        {page==="properties"&&<Properties {...sp}/>}
        {page==="messages"&&<Messages {...sp}/>}
        {page==="cleaning"&&<Cleaning {...sp}/>}
        {page==="pricing"&&<Pricing {...sp}/>}
        {page==="stats"&&<Stats {...sp}/>}
        {page==="locks"&&<Locks {...sp}/>}
        {page==="guides"&&<Guides {...sp}/>}
      </div>
      <nav style={{flexShrink:0,background:"white",borderTop:"1px solid #F0EDE8",display:"flex",padding:"10px 8px 18px",gap:4}}>
        {NAV.map(n=>{
          const isActive=n.id==="more"?(showMore||!NAV.find(x=>x.id===page)):page===n.id;
          return(<button key={n.id} onClick={()=>n.id==="more"?setShowMore(!showMore):navigate(n.id)}
            style={{flex:1,display:"flex",flexDirection:"column",alignItems:"center",gap:4,background:"none",border:"none",cursor:"pointer",padding:"6px 4px",borderRadius:12}}>
            <span style={{fontSize:20,lineHeight:1}}>{n.icon}</span>
            <span style={{fontSize:10.5,fontWeight:isActive?700:500,color:isActive?"#1A1A2E":"#AAA"}}>{n.label}</span>
            {isActive&&<div style={{width:16,height:3,background:"#1A1A2E",borderRadius:2,marginTop:-2}}/>}
          </button>);
        })}
      </nav>
      {showMore&&(<>
        <div className="sheet-bg" onClick={()=>setShowMore(false)}/>
        <div className="sheet" style={{paddingBottom:30}}>
          <div className="sheet-handle"/>
          <div style={{padding:"0 20px 10px"}}>
            <div style={{fontSize:16,fontWeight:700,marginBottom:16,color:"#888"}}>MODULES</div>
            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10}}>
              {MORE_MENU.map(m=>(
                <button key={m.id} onClick={()=>navigate(m.id)}
                  style={{display:"flex",alignItems:"center",gap:12,padding:"16px 14px",background:"#FAFAF8",border:"1.5px solid #F0EDE8",borderRadius:16,cursor:"pointer",textAlign:"left"}}>
                  <span style={{fontSize:24}}>{m.icon}</span>
                  <span style={{fontWeight:600,fontSize:14,color:"#1A1A2E"}}>{m.label}</span>
                </button>
              ))}
            </div>
          </div>
        </div>
      </>)}
      {toast&&<div className="toast">✓ {toast}</div>}
    </div>
  );
}

function EmptyState({icon,title,sub,action,actionLabel}){
  return(<div className="empty-state">
    <div style={{fontSize:48}}>{icon}</div>
    <div style={{fontWeight:700,fontSize:16,color:"#555"}}>{title}</div>
    <div style={{fontSize:14,color:"#AAA",maxWidth:220}}>{sub}</div>
    {action&&<button className="btn btn-primary" style={{marginTop:8}} onClick={action}>{actionLabel}</button>}
  </div>);
}

function Dashboard({navigate,reservations,properties,totalRevenue,activeRes,todayCheckins,todayCheckouts}){
  const dateStr=new Date().toLocaleDateString("fr-FR",{weekday:"long",day:"numeric",month:"long",year:"numeric"});
  const recent=reservations.slice(-3).reverse();
  const alerts=[
    ...(todayCheckins>0?[{icon:"🔑",text:`${todayCheckins} check-in(s) aujourd'hui`,sub:"À préparer",color:"#4CAF93",page:"reservations"}]:[]),
    ...(todayCheckouts>0?[{icon:"🚪",text:`${todayCheckouts} check-out(s) aujourd'hui`,sub:"Ménage à planifier",color:"#F5A623",page:"cleaning"}]:[]),
    ...(properties.length===0?[{icon:"🏠",text:"Ajoutez votre premier bien",sub:"Commencez par créer un logement",color:"#3B9EEB",page:"properties"}]:[]),
  ];
  return(<div style={{display:"flex",flexDirection:"column",height:"100%",overflow:"hidden"}}>
    <div style={{padding:"12px 20px 16px",flexShrink:0}}>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start"}}>
        <div>
          <div style={{fontFamily:"'Playfair Display',serif",fontSize:22,fontWeight:700,letterSpacing:"-0.5px"}}>Bonjour 👋</div>
          <div style={{color:"#888",fontSize:13,marginTop:2,textTransform:"capitalize"}}>{dateStr}</div>
        </div>
        <div style={{width:40,height:40,background:"#1A1A2E",borderRadius:12,display:"flex",alignItems:"center",justifyContent:"center",color:"white",fontSize:14,fontWeight:700}}>MB</div>
      </div>
    </div>
    <div className="page-scroll fade-up">
      <div style={{background:"#1A1A2E",borderRadius:22,padding:"22px 20px",color:"white"}}>
        <div style={{fontSize:12,opacity:0.55,fontWeight:600,letterSpacing:"0.08em",marginBottom:6}}>REVENUS TOTAUX</div>
        <div style={{fontFamily:"'Playfair Display',serif",fontSize:38,fontWeight:700,letterSpacing:"-1.5px",marginBottom:16}}>{fmt(totalRevenue)}</div>
        <div style={{display:"flex",gap:20}}>
          {[["🏠",activeRes,"En cours"],["🔑",todayCheckins,"Check-ins"],["🚪",todayCheckouts,"Check-outs"]].map(([icon,val,lbl])=>(
            <div key={lbl}><div style={{fontSize:20,fontWeight:700}}>{icon} {val}</div><div style={{fontSize:11,opacity:0.5,marginTop:2}}>{lbl}</div></div>
          ))}
        </div>
      </div>
      <div>
        <div className="section-title">Actions rapides</div>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10}}>
          {[{icon:"📋",label:"Réservations",page:"reservations",color:"#E3F2F9"},{icon:"📅",label:"Calendrier",page:"calendar",color:"#FDF3E7"},{icon:"🧹",label:"Ménage",page:"cleaning",color:"#E8F5E9"},{icon:"🔐",label:"Serrures",page:"locks",color:"#F3E5F5"}].map(a=>(
            <button key={a.page} onClick={()=>navigate(a.page)}
              style={{display:"flex",alignItems:"center",gap:12,padding:"16px",background:a.color,border:"none",borderRadius:16,cursor:"pointer",textAlign:"left"}}>
              <span style={{fontSize:26}}>{a.icon}</span>
              <span style={{fontWeight:700,fontSize:15,color:"#1A1A2E"}}>{a.label}</span>
            </button>
          ))}
        </div>
      </div>
      {alerts.length>0&&(
        <div>
          <div className="section-title">🔔 Alertes</div>
          <div className="card" style={{padding:"6px 16px"}}>
            {alerts.map((a,i)=>(
              <div key={i} className="row" style={{cursor:"pointer"}} onClick={()=>navigate(a.page)}>
                <div style={{width:42,height:42,background:a.color+"22",borderRadius:12,display:"flex",alignItems:"center",justifyContent:"center",fontSize:20,flexShrink:0}}>{a.icon}</div>
                <div style={{flex:1}}><div style={{fontWeight:600,fontSize:14}}>{a.text}</div><div style={{fontSize:12.5,color:"#888",marginTop:2}}>{a.sub}</div></div>
                <div style={{color:"#CCC",fontSize:18}}>›</div>
              </div>
            ))}
          </div>
        </div>
      )}
      <div>
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:14}}>
          <div className="section-title" style={{margin:0}}>Réservations récentes</div>
          <button onClick={()=>navigate("reservations")} style={{background:"none",border:"none",color:"#3B9EEB",fontSize:14,fontWeight:600,cursor:"pointer"}}>Voir tout</button>
        </div>
        {recent.length===0?(
          <div className="card" style={{textAlign:"center",padding:"28px 16px",color:"#AAA",fontSize:14}}>Aucune réservation pour l'instant</div>
        ):(
          <div style={{display:"flex",flexDirection:"column",gap:10}}>
            {recent.map(r=>{
              const prop=properties.find(p=>p.id===r.propertyId);
              if(!prop)return null;
              return(<div key={r.id} className="card" style={{padding:"14px 16px"}}>
                <div style={{display:"flex",alignItems:"center",gap:12}}>
                  <div style={{width:44,height:44,background:prop.color,borderRadius:13,display:"flex",alignItems:"center",justifyContent:"center",fontSize:22,flexShrink:0}}>{prop.image}</div>
                  <div style={{flex:1,minWidth:0}}>
                    <div style={{fontWeight:700,fontSize:14,whiteSpace:"nowrap",overflow:"hidden",textOverflow:"ellipsis"}}>{r.client}</div>
                    <div style={{fontSize:12.5,color:"#888",marginTop:2}}>{prop.name} · {r.checkin}</div>
                  </div>
                  <div style={{textAlign:"right",flexShrink:0}}>
                    <div style={{fontWeight:700,fontSize:15}}>{fmt(r.total)}</div>
                    <span className="badge" style={{background:SC[r.status]+"22",color:SC[r.status],marginTop:3}}>{SL[r.status]}</span>
                  </div>
                </div>
              </div>);
            })}
          </div>
        )}
      </div>
    </div>
  </div>);
}

function Properties({properties,setProperties,reservations,showToast}){
  const[selected,setSelected]=useState(null);
  const[showAdd,setShowAdd]=useState(false);
  const[form,setForm]=useState({name:"",type:"apartment",city:"",price:"",rooms:"",capacity:"",image:"🏠"});
  const addProperty=()=>{
    if(!form.name||!form.city||!form.price){showToast("Remplis les champs obligatoires");return;}
    setProperties([...properties,{id:uid(),name:form.name,type:form.type,city:form.city,price:Number(form.price),rooms:Number(form.rooms)||1,capacity:Number(form.capacity)||2,image:form.image,rating:null,amenities:[],color:PCOLORS[properties.length%PCOLORS.length]}]);
    setShowAdd(false);setForm({name:"",type:"apartment",city:"",price:"",rooms:"",capacity:"",image:"🏠"});showToast("Bien ajouté !");
  };
  return(<div style={{display:"flex",flexDirection:"column",height:"100%",overflow:"hidden"}}>
    <div className="page-header">
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center"}}>
        <div style={{fontFamily:"'Playfair Display',serif",fontSize:22,fontWeight:700}}>Mes Biens</div>
        <button className="btn btn-primary btn-sm" onClick={()=>setShowAdd(true)}>+ Ajouter</button>
      </div>
    </div>
    <div className="page-scroll fade-up" style={{gap:12}}>
      {properties.length===0?(
        <EmptyState icon="🏠" title="Aucun bien enregistré" sub="Ajoutez votre premier appartement ou villa" action={()=>setShowAdd(true)} actionLabel="+ Ajouter un bien"/>
      ):properties.map(p=>{
        const rev=reservations.filter(r=>r.propertyId===p.id).reduce((s,r)=>s+(r.total||0),0);
        const active=reservations.find(r=>r.propertyId===p.id&&r.status==="active");
        return(<div key={p.id} className="card" style={{padding:0,overflow:"hidden"}} onClick={()=>setSelected(p)}>
          <div style={{background:p.color,padding:"20px 18px 16px",position:"relative"}}>
            <div style={{position:"absolute",top:14,right:14}}>
              <span className="badge" style={{background:active?"#E8F4EE":"white",color:active?"#4CAF93":"#888",fontSize:12}}>{active?"● Occupé":"○ Libre"}</span>
            </div>
            <div style={{fontSize:40,marginBottom:8}}>{p.image}</div>
            <div style={{fontFamily:"'Playfair Display',serif",fontSize:20,fontWeight:700}}>{p.name}</div>
            <div style={{fontSize:13,color:"#555",marginTop:3}}>📍 {p.city} · {p.rooms} ch. · {p.capacity} pers.</div>
          </div>
          <div style={{padding:"14px 18px"}}>
            <div style={{display:"flex",gap:20}}>
              <div><div style={{fontSize:18,fontWeight:700}}>{fmt(p.price)}<span style={{fontSize:12,color:"#888",fontWeight:400}}>/nuit</span></div></div>
              <div><div style={{fontSize:18,fontWeight:700}}>{fmt(rev)}</div><div style={{fontSize:11,color:"#888"}}>générés</div></div>
            </div>
          </div>
        </div>);
      })}
    </div>
    {selected&&(<>
      <div className="sheet-bg" onClick={()=>setSelected(null)}/>
      <div className="sheet">
        <div className="sheet-handle"/>
        <div style={{padding:"0 20px"}}>
          <div style={{textAlign:"center",marginBottom:20}}>
            <div style={{fontSize:48}}>{selected.image}</div>
            <div style={{fontFamily:"'Playfair Display',serif",fontSize:22,fontWeight:700}}>{selected.name}</div>
            <div style={{color:"#888",fontSize:14,marginTop:4}}>📍 {selected.city}</div>
          </div>
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10,marginBottom:20}}>
           
